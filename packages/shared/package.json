{
  "name": "@gysober/react-use-shared",
  "version": "0.0.0",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "build",
    "dev": "build --watch",
    "test": "vitest run --color",
    "test:coverage": "vitest run --color --coverage"
  },
  "keywords": [
    "react-use",
    "shared"
  ],
  "description": "Shared code for react-use",
  "author": "sober",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "catalog:",
    "@react-use/build": "workspace:*"
  }
}
