{
  "name": "react-use",
  "version": "0.0.0",
  "main": "index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{js,ts,tsx,jsx}\"",
    "lint:fix": "eslint --fix \"**/*.{js,ts,tsx,jsx}\"",
    "lint:check": "eslint \"**/*.{js,ts,tsx,jsx}\"",
    "spellcheck": "cspell lint --dot --gitignore --color --show-suggestions \"**/*.{js,mjs,ts,tsx,jsx}\"",
    "lint-staged": "lint-staged",
    "commit": "git-cz",
    "test": "pnpm --filter=./packages/* test",
    "test:coverage": "cross-env REACT_MODE=strict pnpm --filter=./packages/* test:coverage",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write --parser=typescript"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soberzen/react-use.git"
  },
  "packageManager": "pnpm@11.1.3",
  "author": "sober",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@cspell/dict-lorem-ipsum": "^4.0.5",
    "@eslint/js": "9.36.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-istanbul": "^4.1.10",
    "commitizen": "^4.3.1",
    "commitlint": "^21.0.1",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.0",
    "cz-git": "^1.13.1",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.1.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "3.0.5",
    "eslint-plugin-unicorn": "61.0.2",
    "globals": "16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.44.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24.15.0",
    "pnpm": "11.1.3"
  }
}
